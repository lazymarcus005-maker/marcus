HARNESS_ENV=development

HARNESS_DATABASE_URL=postgresql+asyncpg://harness:harness@localhost:5432/harness
HARNESS_REDIS_URL=redis://localhost:6379/0
HARNESS_RABBITMQ_URL=amqp://harness:harness@localhost:5672/

# OpenAI-compatible endpoint (decisions.md D2 — Ollama cloud by default)
HARNESS_LLM_BASE_URL=https://ollama.com/v1
HARNESS_LLM_API_KEY=changeme
HARNESS_LLM_MODEL=gpt-oss:120b
HARNESS_LLM_TIMEOUT_SECONDS=60

# Used to encrypt MCP server auth headers at rest (Fernet key, 32 url-safe base64 bytes)
HARNESS_SECRET_KEY=changeme-32-bytes-minimum-secret-key!!

HARNESS_RUN_DEFAULT_MAX_STEPS=25
HARNESS_RUN_DEFAULT_MAX_TOOL_CALLS=40
HARNESS_RUN_DEFAULT_TOKEN_BUDGET=200000
HARNESS_RUN_DEFAULT_TIMEOUT_SECONDS=900

HARNESS_APPROVAL_EXPIRY_HOURS=24
HARNESS_RUN_LEASE_TTL_SECONDS=60

# Slack Events API + Web API integration
HARNESS_SLACK_SIGNING_SECRET=
HARNESS_SLACK_BOT_TOKEN=
# Required when more than one tenant exists; otherwise Slack uses the sole tenant.
HARNESS_SLACK_TENANT_ID=
HARNESS_WEB_BASE_URL=http://localhost:8000

# Set to 0 to disable API key rate limiting in local development.
HARNESS_API_KEY_RATE_LIMIT_PER_MINUTE=120

HARNESS_OTEL_ENABLED=true
HARNESS_OTEL_SERVICE_NAME=harness
HARNESS_OTEL_EXPORTER_OTLP_ENDPOINT=
HARNESS_JSON_LOGS=true

HARNESS_SCHEDULER_LEASE_TTL_SECONDS=30
HARNESS_SCHEDULER_POLL_SECONDS=30

HARNESS_TENANT_DAILY_TOKEN_QUOTA_DEFAULT=2000000
HARNESS_TENANT_MAX_ACTIVE_RUNS_DEFAULT=25

# Built-in tools (fetch_url, read_file, write_file, run_cli). read_file,
# write_file, and run_cli are sandboxed to this directory and cannot escape it.
HARNESS_TOOLS_FS_ROOT=./data/tools-fs
HARNESS_TOOLS_FETCH_URL_TIMEOUT_SECONDS=15
HARNESS_TOOLS_FETCH_URL_MAX_BYTES=200000
HARNESS_TOOLS_READ_FILE_MAX_BYTES=200000
# run_cli is DESTRUCTIVE risk tier (every call requires human approval) but
# still runs arbitrary shell commands. Set to false to remove it entirely.
HARNESS_TOOLS_RUN_CLI_ENABLED=true
HARNESS_TOOLS_RUN_CLI_TIMEOUT_SECONDS=30
HARNESS_TOOLS_RUN_CLI_MAX_OUTPUT_BYTES=50000
